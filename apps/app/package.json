{
  "name": "app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "analyze": "npx vite build --mode analyze --config vite.config.ts",
    "test": "vite --mode test",
    "prod": "vite --mode prod --host 0.0.0.0 --port 4173",
    "minify": "npx postcss dist/main.css -o dist/main.css && npx html-minifier-terser dist/index.html --collapse-whitespace --remove-comments --remove-optional-tags --minify-css true --minify-js true -o dist/index.html && node optimize-icons.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "arktype": "^2.2.0",
    "motion": "^12.34.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.23",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "autoprefixer": "^10.4.24",
    "cssnano": "^7.1.2",
    "fast-glob": "^3.3.3",
    "gifsicle": "^7.0.1",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "sass": "^1.97.3",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-image-optimizer": "^2.0.3",
    "vite-plugin-svgr": "^4.5.0"
  }
}
